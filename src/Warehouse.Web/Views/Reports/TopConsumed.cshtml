@model TopConsumedViewModel
@{ ViewData["Title"] = "Top Consumed"; }

<h1 class="h3 mb-3">Top Consumed Products</h1>

<form method="get" class="card-section mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label small">From</label>
            <input type="date" name="from" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small">To</label>
            <input type="date" name="to" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Top</label>
            <select name="topN" class="form-select">
                <option value="5" selected="@(Model.TopN == 5)">5</option>
                <option value="10" selected="@(Model.TopN == 10)">10</option>
                <option value="25" selected="@(Model.TopN == 25)">25</option>
                <option value="50" selected="@(Model.TopN == 50)">50</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100">Apply</button>
        </div>
    </div>
</form>

<div class="table-clean">
    <table class="table mb-0 align-middle">
        <thead>
            <tr><th>#</th><th>SKU</th><th>Product</th><th>Category</th><th class="text-end">Total Consumed</th><th class="text-end">Movements</th></tr>
        </thead>
        <tbody>
            @if (!Model.Rows.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-5">No outgoing movements in this date range.</td></tr>
            }
            @{ int rank = 1; }
            @foreach (var r in Model.Rows)
            {
                <tr>
                    <td class="text-muted">@(rank++)</td>
                    <td><code>@r.SKU</code></td>
                    <td>@r.Name</td>
                    <td class="text-muted">@r.CategoryName</td>
                    <td class="text-end"><strong>@r.TotalConsumed</strong> @r.Unit</td>
                    <td class="text-end text-muted">@r.MovementCount</td>
                </tr>
            }
        </tbody>
    </table>
</div>
