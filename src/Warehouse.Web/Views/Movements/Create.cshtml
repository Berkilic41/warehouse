@model MovementFormViewModel
@{ ViewData["Title"] = $"New {Model.MovementType} Movement"; }

<div class="card-section">
    <h1 class="h4 mb-4">@ViewData["Title"]</h1>
    <form asp-action="Create" method="post" id="movement-form">
        @Html.AntiForgeryToken()
        <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>

        <div class="row">
            <div class="col-md-3 mb-3">
                <label asp-for="MovementType" class="form-label">Type</label>
                <select asp-for="MovementType" class="form-select">
                    <option value="In">Stock In</option>
                    <option value="Out">Stock Out</option>
                    <option value="Adjustment">Adjustment</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Reference" class="form-label">Reference</label>
                <input asp-for="Reference" class="form-control" placeholder="PO-2026-0001 / SO-2026-0042 / ..." />
            </div>
            <div class="col-md-5 mb-3">
                <label asp-for="SupplierId" class="form-label">Supplier (for incoming stock)</label>
                <select asp-for="SupplierId" class="form-select">
                    <option value="">— None —</option>
                    @foreach (var s in Model.AllSuppliers)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Reason" class="form-label">Reason</label>
            <input asp-for="Reason" class="form-control" placeholder="Optional reason" />
        </div>

        <hr />
        <h5 class="mb-3">Items</h5>
        <p class="text-muted small">For Adjustments, use a negative number to decrease stock.</p>

        <table class="table align-middle" id="items-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th style="width:120px">Quantity</th>
                    <th style="width:140px">Unit Price</th>
                    <th style="width:50px"></th>
                </tr>
            </thead>
            <tbody id="items-body">
                @for (int i = 0; i < Model.Items.Count; i++)
                {
                    <tr class="item-row">
                        <td>
                            <select name="Items[@i].ProductId" class="form-select" required>
                                <option value="">Select product...</option>
                                @foreach (var p in Model.AllProducts)
                                {
                                    <option value="@p.Id" selected="@(Model.Items[i].ProductId == p.Id)">
                                        @p.SKU - @p.Name (stock: @p.CurrentStock)
                                    </option>
                                }
                            </select>
                        </td>
                        <td>
                            <input name="Items[@i].Quantity" type="number" value="@Model.Items[i].Quantity" class="form-control" required />
                        </td>
                        <td>
                            <input name="Items[@i].UnitPrice" type="number" step="0.01" value="@Model.Items[i].UnitPrice" class="form-control" />
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <button type="button" id="add-row" class="btn btn-sm btn-outline-primary mb-3">+ Add another item</button>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Notes</label>
            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Record movement</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

<template id="row-template">
    <tr class="item-row">
        <td>
            <select name="Items[__I__].ProductId" class="form-select" required>
                <option value="">Select product...</option>
                @foreach (var p in Model.AllProducts)
                {
                    <option value="@p.Id">@p.SKU - @p.Name (stock: @p.CurrentStock)</option>
                }
            </select>
        </td>
        <td><input name="Items[__I__].Quantity" type="number" value="1" class="form-control" required /></td>
        <td><input name="Items[__I__].UnitPrice" type="number" step="0.01" class="form-control" /></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger remove-row">×</button></td>
    </tr>
</template>

@section Scripts {
    <script src="~/js/movements.js" asp-append-version="true"></script>
}
