@model MovementHistoryViewModel
@{ ViewData["Title"] = "Stock Movements"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Stock Movements</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <div class="btn-group">
            <a asp-action="Create" asp-route-type="In" class="btn btn-success">+ Stock In</a>
            <a asp-action="Create" asp-route-type="Out" class="btn btn-warning">- Stock Out</a>
            <a asp-action="Create" asp-route-type="Adjustment" class="btn btn-secondary">± Adjust</a>
        </div>
    }
</div>

<form method="get" class="card-section mb-3">
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label small mb-1">From</label>
            <input type="date" name="from" value="@Model.FromDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-1">To</label>
            <input type="date" name="to" value="@Model.ToDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">Type</label>
            <select name="type" class="form-select">
                <option value="">All</option>
                <option value="In" selected="@(Model.MovementType == "In")">In</option>
                <option value="Out" selected="@(Model.MovementType == "Out")">Out</option>
                <option value="Adjustment" selected="@(Model.MovementType == "Adjustment")">Adjustment</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small mb-1">Product</label>
            <select name="productId" class="form-select">
                <option value="">All products</option>
                @foreach (var p in Model.AllProducts)
                {
                    <option value="@p.Id" selected="@(Model.ProductId == p.Id)">@p.SKU - @p.Name</option>
                }
            </select>
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button class="btn btn-outline-secondary w-100">Filter</button>
        </div>
    </div>
</form>

<div class="table-clean">
    <table class="table mb-0 align-middle">
        <thead>
            <tr>
                <th>Date</th><th>Type</th><th>Reference</th><th>Items</th>
                <th>Supplier / Reason</th><th>By</th><th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Movements.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-5">No movements found.</td></tr>
            }
            else
            {
                foreach (var m in Model.Movements)
                {
                    string typeBadge = m.MovementType switch {
                        "In" => "bg-success-subtle text-success-emphasis",
                        "Out" => "bg-warning-subtle text-warning-emphasis",
                        _ => "bg-secondary-subtle text-secondary-emphasis"
                    };
                    <tr class="movement-row">
                        <td class="text-muted small">@m.MovementDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td><span class="badge @typeBadge">@m.MovementType</span></td>
                        <td><code>@m.Reference</code></td>
                        <td>@m.Items.Count item@(m.Items.Count == 1 ? "" : "s") · @m.Items.Sum(i => Math.Abs(i.Quantity)) total qty</td>
                        <td class="text-muted small">@(m.SupplierName ?? m.Reason)</td>
                        <td class="text-muted small">@m.UserName</td>
                        <td class="text-end"><a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">View</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
