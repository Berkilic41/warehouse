@model IEnumerable<Product>
@{
    ViewData["Title"] = "Products";
    var categories = ViewBag.Categories as IEnumerable<Category> ?? [];
    var search = ViewBag.Search as string;
    int? selCat = ViewBag.CategoryId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Products</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New product</a>
    }
</div>

<form method="get" class="card-section mb-3">
    <div class="row g-2">
        <div class="col-md-6">
            <input type="text" name="search" value="@search" class="form-control" placeholder="Search by SKU or name..." />
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select">
                <option value="">All categories</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(selCat == c.Id)">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100">Filter</button>
        </div>
    </div>
</form>

<div class="table-clean">
    <table class="table mb-0 align-middle">
        <thead>
            <tr>
                <th>SKU</th><th>Name</th><th>Category</th><th class="text-end">Stock</th>
                <th class="text-end">Min</th><th class="text-end">Price</th><th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-5">No products found.</td></tr>
            }
            else
            {
                foreach (var p in Model)
                {
                    <tr>
                        <td><code>@p.SKU</code></td>
                        <td>@p.Name</td>
                        <td class="text-muted">@p.CategoryName</td>
                        <td class="text-end"><partial name="_StockBadge" model="p" /></td>
                        <td class="text-end text-muted">@p.MinStockThreshold</td>
                        <td class="text-end">@(p.UnitPrice?.ToString("C") ?? "—")</td>
                        <td class="text-end">
                            @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                            {
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
