@model IEnumerable<Supplier>
@{ ViewData["Title"] = "Suppliers"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Suppliers</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New supplier</a>
    }
</div>

<div class="row g-3">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">No suppliers yet.</div>
    }
    @foreach (var s in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card-section h-100 @(s.IsActive ? "" : "opacity-50")">
                <div class="d-flex justify-content-between mb-2">
                    <h5 class="mb-0">@s.Name</h5>
                    @if (!s.IsActive) { <span class="badge bg-secondary">Inactive</span> }
                </div>
                <p class="text-muted small mb-2">@s.ContactName</p>
                @if (!string.IsNullOrEmpty(s.Email))
                {
                    <p class="mb-1 small"><a href="mailto:@s.Email" class="text-decoration-none">📧 @s.Email</a></p>
                }
                @if (!string.IsNullOrEmpty(s.Phone))
                {
                    <p class="mb-1 small">📞 @s.Phone</p>
                }
                @if (!string.IsNullOrEmpty(s.Address))
                {
                    <p class="mb-2 text-muted small">📍 @s.Address</p>
                }
                <div class="d-flex justify-content-between align-items-center pt-2 mt-2 border-top">
                    <span class="text-muted small">@s.ProductCount product@(s.ProductCount == 1 ? "" : "s")</span>
                    <div class="d-flex gap-1">
                        @if (User.IsInRole("Admin") || User.IsInRole("Staff"))
                        {
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
