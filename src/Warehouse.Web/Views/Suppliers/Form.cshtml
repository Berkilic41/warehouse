@model SupplierFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "Edit supplier" : "New supplier";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card-section">
            <h1 class="h4 mb-4">@ViewData["Title"]</h1>
            <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="alert alert-danger" asp-validation-summary="ModelOnly"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ContactName" class="form-label">Contact name</label>
                        <input asp-for="ContactName" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Products supplied</label>
                    <div class="border rounded p-3" style="max-height:300px;overflow-y:auto">
                        @foreach (var p in Model.AllProducts)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="ProductIds"
                                       value="@p.Id" id="prod-@p.Id"
                                       checked="@Model.ProductIds.Contains(p.Id)" />
                                <label class="form-check-label" for="prod-@p.Id">
                                    <code>@p.SKU</code> @p.Name <span class="text-muted small">· @p.CategoryName</span>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">@(isEdit ? "Update" : "Create")</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
